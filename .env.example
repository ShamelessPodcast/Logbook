# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (TEST MODE ONLY)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATE_LOCK_PRICE_ID=price_...

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@logbook.app

# DVLA VES API (UK vehicle enquiry)
DVLA_API_KEY=your-dvla-api-key

# Supabase Storage bucket names
NEXT_PUBLIC_AVATAR_BUCKET=avatars
NEXT_PUBLIC_POST_IMAGES_BUCKET=post-images
NEXT_PUBLIC_LISTING_IMAGES_BUCKET=listing-images
