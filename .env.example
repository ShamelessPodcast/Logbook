# =============================================================
# Logbook — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================

# ── Supabase (required) ──────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App URL (required) ───────────────────────────────────────
# Local dev: http://localhost:3000 | Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase Storage bucket names (required) ─────────────────
NEXT_PUBLIC_AVATAR_BUCKET=avatars
NEXT_PUBLIC_POST_IMAGES_BUCKET=post-images
NEXT_PUBLIC_LISTING_IMAGES_BUCKET=listing-images

# ── Stripe (required for plate lock payments) ────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
# Use TEST keys for development, LIVE keys for production only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATE_LOCK_PRICE_ID=price_...

# ── Resend (required for transactional email) ────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@logbook.app

# ── PlateRecognizer (required for auto plate detection) ──────
# Sign up free at: https://platerecognizer.com/ (2,500 lookups/month free)
PLATE_RECOGNIZER_API_KEY=your_token_here

# ── DVLA VES API (UK vehicle enquiry) ───────────────────────
# Apply at: https://developer-portal.driver-vehicle-licensing.api.gov.uk/
DVLA_API_KEY=your_key_here

# ── DVSA MOT History API ─────────────────────────────────────
# Apply at: https://documentation.history.mot.api.gov.uk/mot-history-api/register
# Free, up to 5 working days for approval
DVSA_MOT_API_KEY=your_key_here

# ── Cron secret (protects /api/cron/* endpoints) ─────────────
CRON_SECRET=generate_a_long_random_string_here

# ── Sentry (optional, error monitoring) ──────────────────────
# Get from: https://sentry.io/settings/YOUR_ORG/projects/
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=logbook
SENTRY_AUTH_TOKEN=your_sentry_auth_token
